    router.Home -> #(HomePageModel(transport.apply_typed_decoder(data, "decode_pages_home__model")), effect.none())
    router.About -> #(AboutPageModel(transport.apply_typed_decoder(data, "decode_pages_about_model")), effect.none())
    router.UsersId(_id) -> #(UsersIdPageModel(transport.apply_typed_decoder(data, "decode_pages_users_id__model")), effect.none())
    _ -> #(NoPageModel, effect.none())
  }
}

fn reinit_server(route: router.Route) -> Effect(Msg) {
  case route {
    router.Home -> {
      transport.send_page_init("Home", Nil)
      effect.none()
    }
    router.About -> {
      transport.send_page_init("About", Nil)
      effect.none()
    }
    router.UsersId(id) -> {
      transport.send_page_init("UsersId", id)
      effect.none()
    }
    _ -> effect.none()
  }
}

fn update_page(page_model: PageModel, page_msg: PageMsg, client_context: client_context.ClientContext) -> #(PageModel, Effect(Msg), Option(client_context.ClientContextMsg)) {
  case page_model, page_msg {
    HomePageModel(m), HomePageMsg(msg) -> {
      let #(new_m, e) = pages_home_.update(client_context, m, msg)
      #(HomePageModel(new_m), effect.map(e, fn(msg) { PageMsg(HomePageMsg(msg)) }), None)
    }
    AboutPageModel(m), AboutPageMsg(msg) -> {
      let #(new_m, e) = pages_about.update(client_context, m, msg)
      #(AboutPageModel(new_m), effect.map(e, fn(msg) { PageMsg(AboutPageMsg(msg)) }), None)
    }
    UsersIdPageModel(m), UsersIdPageMsg(msg) -> {
      let #(new_m, e) = pages_users_id_.update(client_context, m, msg)
      #(UsersIdPageModel(new_m), effect.map(e, fn(msg) { PageMsg(UsersIdPageMsg(msg)) }), None)
