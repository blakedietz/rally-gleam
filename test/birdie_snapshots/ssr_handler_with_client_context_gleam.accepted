pub fn handle_request(
  route: router.Route,
  server_context: ServerContext,
  session_id: String,
  hostname: String,
) -> response.Response(ResponseData) {
  case route {
    router.Home -> {
      let #(client_context, server_context) = server_context.from_session(server_context, session_id, hostname)
      let model = pages_home_.load(server_context)
          let rendered = element.to_string(pages_home_.view(client_context, model))
      let ctx_tag = context_script(server_context, session_id, hostname)
      let flags = codec.encode_flags(model)
      let flags_tag = "<script>window.__RALLY_FLAGS__='" <> flags <> "'</script>"
      let shell = shell_html()
      let full_html = string.replace(shell, "<div id='app'></div>", "<div id='app'>" <> rendered <> "</div>")
        <> ctx_tag <> flags_tag
      response.new(200)
      |> response.set_body(mist.Bytes(bytes_tree.from_string(full_html)))
    }
    router.About -> {
      let #(client_context, server_context) = server_context.from_session(server_context, session_id, hostname)
      let model = pages_about.load(server_context)
          let rendered = element.to_string(pages_about.view(client_context, model))
      let ctx_tag = context_script(server_context, session_id, hostname)
      let flags = codec.encode_flags(model)
      let flags_tag = "<script>window.__RALLY_FLAGS__='" <> flags <> "'</script>"
      let shell = shell_html()
      let full_html = string.replace(shell, "<div id='app'></div>", "<div id='app'>" <> rendered <> "</div>")
        <> ctx_tag <> flags_tag
      response.new(200)
      |> response.set_body(mist.Bytes(bytes_tree.from_string(full_html)))
    }
    router.UsersId(id) -> {
      let #(client_context, server_context) = server_context.from_session(server_context, session_id, hostname)
      let model = pages_users_id_.load(id, server_context)
          let rendered = element.to_string(pages_users_id_.view(client_context, model))
      let ctx_tag = context_script(server_context, session_id, hostname)
      let flags = codec.encode_flags(model)
      let flags_tag = "<script>window.__RALLY_FLAGS__='" <> flags <> "'</script>"
      let shell = shell_html()
      let full_html = string.replace(shell, "<div id='app'></div>", "<div id='app'>" <> rendered <> "</div>")
        <> ctx_tag <> flags_tag
      response.new(200)
      |> response.set_body(mist.Bytes(bytes_tree.from_string(full_html)))
    }
    router.NotFound(_) ->
      response.new(404)
      |> response.set_body(mist.Bytes(bytes_tree.from_string("Not found")))
    _ -> serve_html_shell(server_context, session_id, hostname)
  }
}
fn context_script(server_context: ServerContext, session_id: String, hostname: String) -> String {
  let #(client_context, _) = server_context.from_session(server_context, session_id, hostname)
  let encoded = codec.encode_flags(client_context)
  "<script>window.__RALLY_CLIENT_CONTEXT__='" <> encoded <> "'</script>"
}

fn serve_html_shell(server_context: ServerContext, session_id: String, hostname: String) -> response.Response(ResponseData) {
  let html = "<!DOCTYPE html>\n<html>\n<head><meta charset='utf-8'><script>(function(){var c=document.cookie;if(c.includes('__rally_dark_mode=1')||(!c.includes('__rally_dark_mode=')&&window.matchMedia('(prefers-color-scheme:dark)').matches)){document.documentElement.classList.add('dark')}})()</script></head>\n<body><div id='app'></div><script type='module' src='/_build/client/generated/app.mjs'></script></body>\n</html>" <> context_script(server_context, session_id, hostname)
  response.new(200)
  |> response.set_header("content-type", "text/html")
  |> response.set_body(mist.Bytes(bytes_tree.from_string(html)))
}

fn shell_html() -> String {
  "<!DOCTYPE html>\n<html>\n<head><meta charset='utf-8'><script>(function(){var c=document.cookie;if(c.includes('__rally_dark_mode=1')||(!c.includes('__rally_dark_mode=')&&window.matchMedia('(prefers-color-scheme:dark)').matches)){document.documentElement.classList.add('dark')}})()</script></head>\n<body><div id='app'></div><script type='module' src='/_build/client/generated/app.mjs'></script></body>\n</html>"
}

