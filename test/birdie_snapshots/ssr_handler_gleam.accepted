// Generated by Rally — do not edit.

import gleam/bytes_tree
import gleam/http/response
import mist.{type ResponseData}
import generated/router
import rally_runtime/env
import server_context.{type ServerContext}
import rally_runtime/codec
import gleam/result
import gleam/string
import lustre/element
import pages/about as pages_about
import pages/home_ as pages_home_
import pages/users/id_ as pages_users_id_

pub fn handle_request(
  route: router.Route,
  server_context: ServerContext,
  session_id: String,
  hostname: String,
) -> response.Response(ResponseData) {
  case route {
    router.Home -> {
      let model = pages_home_.load(server_context)
          let rendered = element.to_string(pages_home_.view(model))
      let flags = codec.encode_flags(model)
      let flags_tag = "<script>window.__RALLY_FLAGS__='" <> flags <> "'</script>"
      let shell = shell_html()
      let full_html = insert_rendered(shell, rendered)
        <> env.browser_env_script() <> flags_tag
      response.new(200)
      |> response.set_body(mist.Bytes(bytes_tree.from_string(full_html)))
    }
    router.About -> {
      let model = pages_about.load(server_context)
          let rendered = element.to_string(pages_about.view(model))
      let flags = codec.encode_flags(model)
      let flags_tag = "<script>window.__RALLY_FLAGS__='" <> flags <> "'</script>"
      let shell = shell_html()
      let full_html = insert_rendered(shell, rendered)
        <> env.browser_env_script() <> flags_tag
      response.new(200)
      |> response.set_body(mist.Bytes(bytes_tree.from_string(full_html)))
    }
    router.UsersId(id) -> {
      let model = pages_users_id_.load(id, server_context)
          let rendered = element.to_string(pages_users_id_.view(model))
      let flags = codec.encode_flags(model)
      let flags_tag = "<script>window.__RALLY_FLAGS__='" <> flags <> "'</script>"
      let shell = shell_html()
      let full_html = insert_rendered(shell, rendered)
        <> env.browser_env_script() <> flags_tag
      response.new(200)
      |> response.set_body(mist.Bytes(bytes_tree.from_string(full_html)))
    }
    router.NotFound(_) ->
      response.new(404)
      |> response.set_body(mist.Bytes(bytes_tree.from_string("Not found")))
    _ -> serve_html_shell()
  }
}
fn serve_html_shell() -> response.Response(ResponseData) {
  let html = "<!DOCTYPE html>\n<html>\n<head><meta charset='utf-8'><script>(function(){var c=document.cookie;if(c.includes('__rally_dark_mode=1')||(!c.includes('__rally_dark_mode=')&&window.matchMedia('(prefers-color-scheme:dark)').matches)){document.documentElement.classList.add('dark')}})()</script></head>\n<body><div id='app'></div><script type='module' src='/_build/client/generated/app.mjs'></script></body>\n</html>" <> env.browser_env_script()
  response.new(200)
  |> response.set_header("content-type", "text/html")
  |> response.set_body(mist.Bytes(bytes_tree.from_string(html)))
}

fn shell_html() -> String {
  "<!DOCTYPE html>\n<html>\n<head><meta charset='utf-8'><script>(function(){var c=document.cookie;if(c.includes('__rally_dark_mode=1')||(!c.includes('__rally_dark_mode=')&&window.matchMedia('(prefers-color-scheme:dark)').matches)){document.documentElement.classList.add('dark')}})()</script></head>\n<body><div id='app'></div><script type='module' src='/_build/client/generated/app.mjs'></script></body>\n</html>"
}

fn insert_rendered(shell: String, rendered: String) -> String {
  case find_app_marker(shell) {
    Ok(marker) -> string.replace(shell, marker, marker <> rendered)
    Error(_) -> shell
  }
}

fn find_app_marker(shell: String) -> Result(String, Nil) {
  // Find the element with id=app (any tag, any attributes, any quoting).
  let id_dq = "id=\"app\""
  let id_sq = "id='app'"
  let id_dq_spaced = "id = \"app\""
  let id_sq_spaced = "id = 'app'"
  let id_attr = case string.contains(shell, id_dq) {
    True -> Ok(id_dq)
    False -> case string.contains(shell, id_sq) {
      True -> Ok(id_sq)
      False -> case string.contains(shell, id_dq_spaced) {
        True -> Ok(id_dq_spaced)
        False -> case string.contains(shell, id_sq_spaced) {
          True -> Ok(id_sq_spaced)
          False -> Error(Nil)
        }
      }
    }
  }
  use id_attr <- result.try(id_attr)
  use #(before_id, after_id) <- result.try(string.split_once(shell, id_attr))
  let reversed_before = string.reverse(before_id)
  use #(after_lt_rev, _) <- result.try(string.split_once(reversed_before, "<"))
  let tag_start = "<" <> string.reverse(after_lt_rev)
  use #(tag_end, _) <- result.try(string.split_once(after_id, ">"))
  Ok(tag_start <> id_attr <> tag_end <> ">")
}

