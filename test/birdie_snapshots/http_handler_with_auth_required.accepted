                  |> response.set_body(mist.Bytes(bytes_tree.from_string("Unknown RPC")))
                Ok(info) -> {
                  let page = info.page
                  let required = info.required
                  let has_authorize = info.has_authorize
                  case required && !auth.is_authenticated(identity) {
                    True ->
                      response.new(401)
                      |> response.set_body(mist.Bytes(bytes_tree.from_string("Authentication required")))
                    False -> {
                      let #(_, server_context) = client_context_server.from_session(server_context: server_context, session_id: session_id, hostname: hostname, identity: identity)
