                Error(Nil) -> {
                  let result =
                    wire.error_result(wire.rpc_request_id(envelope), "Unknown RPC")
                  response.new(400)
                  |> response.set_header("content-type", wire.rpc_content_type())
                  |> response.set_body(mist.Bytes(wire.rpc_result_body(result)))
                }
                Ok(info) -> {
                  let page = info.page
                  let required = info.required
                  let has_authorize = info.has_authorize
                  case required && !auth.is_authenticated(identity) {
                    True -> {
                      let result =
                        wire.auth_error_result(wire.rpc_request_id(envelope), "Authentication required")
                      response.new(401)
                      |> response.set_header("content-type", wire.rpc_content_type())
                      |> response.set_body(mist.Bytes(wire.rpc_result_body(result)))
                    }
                    False -> {
                      let #(_, server_context) = client_context_server.from_session(server_context: server_context, session_id: session_id, hostname: hostname, identity: identity)
