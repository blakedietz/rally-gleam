fn handler_page_info(variant: String) -> Result(PageAuthInfo, Nil) {
  case variant {
    "server_load_data" -> Ok(PageAuthInfo(page: "Test", required: True, has_authorize: False))
    "7f1a8467d6" -> Ok(PageAuthInfo(page: "Test", required: True, has_authorize: False))
