// Generated by Lando — do not edit.
import lustre
import lustre/attribute as attr
import lustre/element.{type Element}
import lustre/element/html
import lustre/effect.{type Effect}
import modem
import generated/codec
import generated/router
import generated/transport
import generated/views

pub type PageModel {
  HomePageModel(views.HomeModel)
  AboutPageModel(views.AboutModel)
  UsersIdPageModel(views.UsersIdModel)
  NoPageModel
}

pub type PageMsg {
  HomePageMsg(views.HomeMsg)
  AboutPageMsg(views.AboutMsg)
  UsersIdPageMsg(views.UsersIdMsg)
}

pub type Model {
  Model(
    route: router.Route,
    page_model: PageModel,
    connection: Connection,
  )
}

pub type Connection {
  Connected
  Disconnected
  Reconnecting
}

pub type Msg {
  UrlChanged(router.Route)
  PageMsg(PageMsg)
  TransportConnected
  TransportDisconnected(reason: String)
}

pub fn main() {
  let app = lustre.application(init, update, view)
  lustre.start(app, "#app", Nil)
}

fn init(_flags: Nil) -> #(Model, Effect(Msg)) {
  let route = router.parse_route_from_url()
  let flags = transport.read_flags()
  let #(page_model, page_effects) = case codec.decode_flags(flags) {
    Ok(model) -> #(hydrate_page(route, model), effect.none())
    Error(_) -> init_page(route)
  }
  #(Model(route:, page_model:, connection: Disconnected),
    effect.batch([init_transport(), modem.init(fn(uri) { UrlChanged(router.parse_route(uri)) }), page_effects]))
}

fn init_transport() -> Effect(Msg) {
  effect.from(fn(dispatch) {
    let _ = transport.init("/ws")
    let _ = transport.register_on_connect(fn() { dispatch(TransportConnected) })
    let _ = transport.register_on_disconnect(fn(reason) { dispatch(TransportDisconnected(reason)) })

    Nil
  })
}

fn init_page(route: router.Route) -> #(PageModel, Effect(Msg)) {
  case route {
    router.Home -> {
      let #(m, e) = views.home_init()
      #(HomePageModel(m), effect.map(e, fn(msg) { PageMsg(HomePageMsg(msg)) }))
    }
    router.About -> {
      let #(m, e) = views.about_init()
      #(AboutPageModel(m), effect.map(e, fn(msg) { PageMsg(AboutPageMsg(msg)) }))
    }
    router.UsersId(id) -> {
      transport.send_page_init("UsersId", id)
      let #(m, e) = views.users_id_init(id)
      #(UsersIdPageModel(m), effect.map(e, fn(msg) { PageMsg(UsersIdPageMsg(msg)) }))
    }
    _ -> #(NoPageModel, effect.none())
  }
}

fn hydrate_page(route: router.Route, model: a) -> PageModel {
  case route {
    router.Home -> HomePageModel(model)
    router.About -> AboutPageModel(model)
    router.UsersId(id) -> UsersIdPageModel(model)
    _ -> NoPageModel
  }
}

fn reinit_server(route: router.Route) -> Effect(Msg) {
  case route {
    router.Home -> {
      transport.send_page_init("Home", Nil)
      effect.none()
    }
    router.About -> {
      transport.send_page_init("About", Nil)
      effect.none()
    }
    router.UsersId(id) -> {
      transport.send_page_init("UsersId", id)
      effect.none()
    }
    _ -> effect.none()
  }
}

fn update_page(page_model: PageModel, page_msg: PageMsg) -> #(PageModel, Effect(Msg)) {
  case page_model, page_msg {
    HomePageModel(m), HomePageMsg(msg) -> {
      let #(new_m, e) = views.home_update(m, msg)
      #(HomePageModel(new_m), effect.map(e, fn(msg) { PageMsg(HomePageMsg(msg)) }))
    }
    AboutPageModel(m), AboutPageMsg(msg) -> {
      let #(new_m, e) = views.about_update(m, msg)
      #(AboutPageModel(new_m), effect.map(e, fn(msg) { PageMsg(AboutPageMsg(msg)) }))
    }
    UsersIdPageModel(m), UsersIdPageMsg(msg) -> {
      let #(new_m, e) = views.users_id_update(m, msg)
      #(UsersIdPageModel(new_m), effect.map(e, fn(msg) { PageMsg(UsersIdPageMsg(msg)) }))
    }
    _, _ -> #(page_model, effect.none())
  }
}

fn render_page(page_model: PageModel) -> Element(Msg) {
  case page_model {
    HomePageModel(m) ->
      element.map(views.home_view(m), fn(msg) { PageMsg(HomePageMsg(msg)) })
    AboutPageModel(m) ->
      element.map(views.about_view(m), fn(msg) { PageMsg(AboutPageMsg(msg)) })
    UsersIdPageModel(m) ->
      element.map(views.users_id_view(m), fn(msg) { PageMsg(UsersIdPageMsg(msg)) })
    NoPageModel -> html.div([], [html.text("Page not found")])
  }
}

fn update(model: Model, msg: Msg) -> #(Model, Effect(Msg)) {
  case msg {
    UrlChanged(route) -> {
      let #(page_model, page_effects) = init_page(route)
      #(Model(..model, route:, page_model:), page_effects)
    }
    PageMsg(page_msg) -> {
      let #(page_model, page_effects) = update_page(model.page_model, page_msg)
      #(Model(..model, page_model:), page_effects)
    }
    TransportConnected ->
      #(Model(..model, connection: Connected), reinit_server(model.route))
    TransportDisconnected(_reason) ->
      #(Model(..model, connection: Disconnected), effect.none())
  }
}

fn view(model: Model) -> Element(Msg) {
  html.div([attr.class("lando-app")], [
    render_page(model.page_model),
    connection_banner(model.connection),
  ])
}

fn connection_banner(connection: Connection) -> Element(Msg) {
  case connection {
    Connected -> html.text("")
    Disconnected ->
      html.div(
        [attr.class("lando-banner lando-banner--disconnected")],
        [html.text("Disconnected from server. Reconnecting...")],
      )
    Reconnecting ->
      html.div(
        [attr.class("lando-banner lando-banner--reconnecting")],
        [html.text("Reconnecting...")],
      )
  }
}

