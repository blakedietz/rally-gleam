// Home — pages/home_
pub type HomeModel {
  HomeModel(
    articles: List(ArticlePreview),
    tags: List(String),
    active_tab: Tab,
    page: Int,
    total: Int,
  )
}

pub type HomeMsg {
  ClickedTab(value: Tab)
  ClickedPage(value: Int)
  ClickedTag(value: String)
  GotArticles(value: Result(#(List(ArticlePreview), Int), Nil))
}

fn home_send_to_server(msg: a) -> Effect(b) {
  effect.from(fn(_dispatch) {
    transport.send_to_server("Home", msg)
    Nil
  })
}

pub fn home_init(
  _client_context: ClientContext,
) -> #(HomeModel, Effect(HomeMsg)) {
  #(
    HomeModel(articles: [], tags: [], active_tab: GlobalFeed, page: 1, total: 0),
    effect.none(),
  )
}

pub fn home_update(
  _client_context: ClientContext,
  model: HomeModel,
  msg: HomeMsg,
) -> #(HomeModel, Effect(HomeMsg)) {
  case msg {
    ClickedTab(tab) -> {
      let #(tab_name, tag) = tab_to_wire(tab)
      #(
        HomeModel(..model, active_tab: tab, page: 1),
        rally_effect.rpc(
          ServerSwitchTab(tab_name:, tag:),
          on_response: GotArticles,
        ),
      )
    }
    ClickedPage(page) -> {
      let #(tab_name, tag) = tab_to_wire(model.active_tab)
      #(
        HomeModel(..model, page:),
        rally_effect.rpc(
          ServerChangePage(page:, tab_name:, tag:),
          on_response: GotArticles,
        ),
      )
    }
    ClickedTag(tag) -> {
      #(
        HomeModel(..model, active_tab: TagFeed(tag:), page: 1),
        rally_effect.rpc(
          ServerSwitchTab(tab_name: "tag", tag:),
          on_response: GotArticles,
        ),
      )
    }
    GotArticles(Ok(#(articles, total))) -> #(
      HomeModel(..model, articles:, total:),
      effect.none(),
    )
    GotArticles(Error(_)) -> #(model, effect.none())
  }
}

pub fn home_view(
  client_context: ClientContext,
  model: HomeModel,
) -> Element(HomeMsg) {
  html.div([attr.class("home-page")], [
    banner(),
    html.div([attr.class("container page")], [
      html.div([attr.class("row")], [
        html.div([attr.class("col-md-9")], [
          feed_toggle(client_context, model.active_tab),
          ..list.map(model.articles, article_preview)
        ]),
        html.div([attr.class("col-md-3")], [sidebar(model.tags)]),
      ]),
      pagination(model.page, model.total),
    ]),
  ])
}

