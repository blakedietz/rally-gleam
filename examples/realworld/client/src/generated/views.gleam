  )
}

pub type EditorSlugMsg {
  UpdatedTitle(value: String)
  UpdatedDescription(value: String)
  UpdatedBody(value: String)
  UpdatedTagInput(value: String)
  AddedTag
  RemovedTag(value: String)
  ClickedUpdate
  EditorSlugGotServerMsg(value: EditorSlugToClient)
}

fn editor_slug_send_to_server(msg: a) -> Effect(b) {
  effect.from(fn(_dispatch) {
    transport.send_to_server("EditorSlug", msg)
    Nil
  })
}

pub fn editor_slug_init(
  _client_context: ClientContext,
  _slug: String,
) -> #(EditorSlugModel, Effect(EditorSlugMsg)) {
  #(
    EditorSlugModel(
      slug: "",
      title: "",
      description: "",
      body: "",
      tag_input: "",
      tags: [],
      errors: [],
      loaded: False,
    ),
    effect.none(),
  )
}

pub fn editor_slug_update(
  _client_context: ClientContext,
  model: EditorSlugModel,
  msg: EditorSlugMsg,
) -> #(EditorSlugModel, Effect(EditorSlugMsg)) {
  case msg {
    UpdatedTitle(val) -> #(EditorSlugModel(..model, title: val), effect.none())
    UpdatedDescription(val) -> #(
      EditorSlugModel(..model, description: val),
      effect.none(),
    )
    UpdatedBody(val) -> #(EditorSlugModel(..model, body: val), effect.none())
    UpdatedTagInput(val) -> #(
      EditorSlugModel(..model, tag_input: val),
      effect.none(),
    )
    AddedTag -> {
      let tag = string.trim(model.tag_input)
      case tag == "" || list.contains(model.tags, tag) {
        True -> #(model, effect.none())
        False -> #(
          EditorSlugModel(
            ..model,
            tags: list.append(model.tags, [tag]),
            tag_input: "",
          ),
          effect.none(),
        )
      }
    }
    RemovedTag(tag) -> #(
      EditorSlugModel(
        ..model,
        tags: list.filter(model.tags, fn(t) { t != tag }),
      ),
      effect.none(),
    )
    ClickedUpdate -> #(
      model,
      editor_slug_send_to_server(UpdateArticle(
        title: model.title,
        description: model.description,
        body: model.body,
        tags: model.tags,
      )),
    )
    EditorSlugGotServerMsg(ArticleLoaded(title, description, body, tags)) -> #(
      EditorSlugModel(..model, title:, description:, body:, tags:, loaded: True),
      effect.none(),
    )
    EditorSlugGotServerMsg(ArticleUpdated(_slug)) -> #(
      EditorSlugModel(..model, errors: []),
      effect.none(),
    )
    EditorSlugGotServerMsg(EditorErrors(errors)) -> #(
      EditorSlugModel(..model, errors:),
      effect.none(),
    )
  }
}

