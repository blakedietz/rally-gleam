// ArticleSlug — pages/article/slug_
pub type ArticleSlugModel {
  ArticleSlugModel(
    article: Option(Article),
    comments: List(Comment),
    is_favorited: Bool,
    is_following: Bool,
    favorites_count: Int,
    comment_body: String,
    errors: List(String),
  )
}

pub type ArticleSlugMsg {
  ClickedFavorite
  ClickedFollow(value: String)
  UpdatedComment(value: String)
  ClickedSubmitComment
  ClickedDeleteComment(value: Int)
  ClickedDeleteArticle
  ArticleSlugGotServerMsg(value: ArticleSlugToClient)
}

fn article_slug_send_to_server(msg: a) -> Effect(b) {
  effect.from(fn(_dispatch) {
    transport.send_to_server("ArticleSlug", msg)
    Nil
  })
}

pub fn article_slug_init(
  _client_context: ClientContext,
  _slug: String,
) -> #(ArticleSlugModel, Effect(ArticleSlugMsg)) {
  #(
    ArticleSlugModel(
      article: None,
      comments: [],
      is_favorited: False,
      is_following: False,
      favorites_count: 0,
      comment_body: "",
      errors: [],
    ),
    effect.none(),
  )
}

pub fn article_slug_update(
  _client_context: ClientContext,
  model: ArticleSlugModel,
  msg: ArticleSlugMsg,
) -> #(ArticleSlugModel, Effect(ArticleSlugMsg)) {
  case msg {
    ClickedFavorite -> #(model, article_slug_send_to_server(ToggleFavorite))
    ClickedFollow(username) -> #(
      model,
      article_slug_send_to_server(ToggleFollow(username:)),
    )
    UpdatedComment(val) -> #(
      ArticleSlugModel(..model, comment_body: val),
      effect.none(),
    )
    ClickedSubmitComment -> #(
      ArticleSlugModel(..model, comment_body: ""),
      article_slug_send_to_server(SubmitComment(body: model.comment_body)),
    )
    ClickedDeleteComment(id) -> #(
      model,
      article_slug_send_to_server(DeleteComment(id:)),
    )
    ClickedDeleteArticle -> #(model, article_slug_send_to_server(DeleteArticle))
    ArticleSlugGotServerMsg(ArticleData(
      article,
      comments,
      is_favorited,
      is_following,
      favorites_count,
    )) -> #(
      ArticleSlugModel(
        ..model,
        article: Some(article),
        comments:,
        is_favorited:,
        is_following:,
        favorites_count:,
      ),
      effect.none(),
    )
    ArticleSlugGotServerMsg(FavoriteUpdated(count, is_favorited)) -> #(
      ArticleSlugModel(..model, favorites_count: count, is_favorited:),
      effect.none(),
    )
    ArticleSlugGotServerMsg(FavoriteCountUpdated(count)) -> #(
      ArticleSlugModel(..model, favorites_count: count),
      effect.none(),
    )
    ArticleSlugGotServerMsg(FollowUpdated(is_following)) -> #(
      ArticleSlugModel(..model, is_following:),
      effect.none(),
    )
    ArticleSlugGotServerMsg(CommentAdded(comment)) -> #(
      ArticleSlugModel(
        ..model,
        comments: list.append(model.comments, [comment]),
      ),
      effect.none(),
    )
    ArticleSlugGotServerMsg(CommentRemoved(id)) -> #(
      ArticleSlugModel(
        ..model,
        comments: list.filter(model.comments, fn(c) { c.id != id }),
      ),
      effect.none(),
    )
    ArticleSlugGotServerMsg(ArticleDeleted) -> #(model, effect.none())
    ArticleSlugGotServerMsg(ArticleError(err)) -> #(
      ArticleSlugModel(..model, errors: [err]),
      effect.none(),
    )
  }
}

pub fn article_slug_view(
  client_context: ClientContext,
  model: ArticleSlugModel,
) -> Element(ArticleSlugMsg) {
  case model.article {
    None ->
      html.div([attr.class("article-page")], [
