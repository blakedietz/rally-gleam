    ProfileUsernameGotServerMsg(ProfileData(profile, articles, is_following)) -> #(
      ProfileUsernameModel(
        ..model,
        profile: Some(profile),
        articles:,
        is_following:,
      ),
      effect.none(),
    )
    ProfileUsernameGotServerMsg(FollowUpdated(is_following)) -> #(
      ProfileUsernameModel(..model, is_following:),
      effect.none(),
    )
    ProfileUsernameGotServerMsg(ProfileArticles(articles)) -> #(
      ProfileUsernameModel(..model, articles:),
      effect.none(),
    )
