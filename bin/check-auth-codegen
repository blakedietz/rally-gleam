#!/usr/bin/env bash
# On-demand auth codegen compile check. Not part of `gleam test`.
# Creates a minimal auth app in ./tmp, runs codegen, builds, cleans up.
#
# Covers: Required+authorize page with server handler, from_session,
#         LoadResult.Page, no-init_loaded page, auth zero-handler namespace.
set -euo pipefail

RALLY_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
APP_DIR="$RALLY_ROOT/tmp/auth_check_$$"

cleanup() {
  if [ "${KEEP_AUTH_CHECK:-}" != "1" ]; then
    rm -rf "$APP_DIR"
  else
    echo "Keeping $APP_DIR for debugging"
  fi
}
trap cleanup EXIT

echo "=== Rally auth codegen check ==="

mkdir -p "$APP_DIR/src/admin/pages" "$APP_DIR/src/public/pages" "$APP_DIR/test"

# --- gleam.toml ---
cat > "$APP_DIR/gleam.toml" <<TOML
name = "auth_check"
version = "0.1.0"
target = "erlang"

[dependencies]
gleam_erlang = ">= 1.0.0 and < 2.0.0"
gleam_http = ">= 4.0.0 and < 5.0.0"
gleam_stdlib = ">= 0.60.0 and < 2.0.0"
rally = { path = "$RALLY_ROOT" }
libero = { path = "$RALLY_ROOT/../libero" }
lustre = ">= 5.6.0 and < 7.0.0"
mist = ">= 6.0.0 and < 7.0.0"
gleam_time = ">= 1.7.0 and < 2.0.0"

[dev-dependencies]
gleeunit = ">= 1.0.0 and < 2.0.0"

[[tools.rally.clients]]
namespace = "admin"
route_root = "/admin"

[[tools.rally.clients]]
namespace = "public"
route_root = "/"
TOML

# --- server_context.gleam ---
echo 'pub type ServerContext { ServerContext }' > "$APP_DIR/src/server_context.gleam"

# --- admin/auth.gleam ---
cat > "$APP_DIR/src/admin/auth.gleam" <<'GLEAM'
import server_context.{type ServerContext}

pub type Identity {
  Authenticated(user_id: Int, role: String)
  Anonymous
}

pub fn resolve(_server_context: ServerContext, _session_id: String) -> Result(Identity, Nil) {
  Ok(Anonymous)
}

pub fn is_authenticated(identity: Identity) -> Bool {
  case identity { Authenticated(..) -> True  Anonymous -> False }
}

pub const redirect_url = "/admin/login"
GLEAM

# --- admin/client_context_server.gleam ---
cat > "$APP_DIR/src/admin/client_context_server.gleam" <<'GLEAM'
import admin/auth
import server_context.{type ServerContext}

pub type ClientContext { ClientContext }

pub fn from_session(
  server_context server_context: ServerContext,
  session_id _session_id: String,
  hostname _hostname: String,
  identity _identity: auth.Identity,
) -> #(ClientContext, ServerContext) {
  #(ClientContext, server_context)
}
GLEAM

# --- admin/shell.html ---
echo '<html><head></head><body><div id="app"></div></body></html>' > "$APP_DIR/src/admin/shell.html"
echo '<html><head></head><body><div id="app"></div></body></html>' > "$APP_DIR/src/public/shell.html"

# --- admin/pages/dashboard.gleam: Required + authorize + server handler ---
cat > "$APP_DIR/src/admin/pages/dashboard.gleam" <<'GLEAM'
import admin/auth
import lustre/element
import lustre/effect
import rally_runtime/auth as rally_auth
import server_context.{type ServerContext}

pub const page_auth = rally_auth.Required

pub type Model { Model(count: Int) }
pub type Msg { NoOp }

pub type ServerIncrement { ServerIncrement(amount: Int) }

pub fn authorize(_server_context: ServerContext, identity: auth.Identity) -> Bool {
  case identity { auth.Authenticated(..) -> True  _ -> False }
}

pub fn server_increment(
  msg: ServerIncrement,
  _server_context: ServerContext,
  _identity: auth.Identity,
) -> Result(Int, Nil) {
  Ok(msg.amount)
}

pub fn load(
  _server_context: ServerContext,
  _identity: auth.Identity,
) -> rally_auth.LoadResult(Model) {
  rally_auth.Page(data: Model(count: 0), cookies: [])
}

pub fn init() -> #(Model, effect.Effect(Msg)) { #(Model(count: 0), effect.none()) }
pub fn view(_model: Model) -> element.Element(Msg) { element.none() }
pub fn update(model: Model, _msg: Msg) -> #(Model, effect.Effect(Msg)) { #(model, effect.none()) }
GLEAM

# --- admin/pages/about.gleam: no init_loaded (exercises data/model variable path) ---
cat > "$APP_DIR/src/admin/pages/about.gleam" <<'GLEAM'
import admin/auth
import lustre/element
import lustre/effect
import rally_runtime/auth as rally_auth
import server_context.{type ServerContext}

pub const page_auth = rally_auth.Optional

pub type Model { Model(info: String) }
pub type Msg { NoOp }

pub fn load(
  _server_context: ServerContext,
  _identity: auth.Identity,
) -> rally_auth.LoadResult(Model) {
  rally_auth.Page(data: Model(info: "about"), cookies: [])
}

pub fn init() -> #(Model, effect.Effect(Msg)) { #(Model(info: ""), effect.none()) }
pub fn view(_model: Model) -> element.Element(Msg) { element.none() }
pub fn update(model: Model, _msg: Msg) -> #(Model, effect.Effect(Msg)) { #(model, effect.none()) }
GLEAM

# --- public/auth.gleam: enables auth zero-handler namespace ---
cat > "$APP_DIR/src/public/auth.gleam" <<'GLEAM'
import server_context.{type ServerContext}

pub type Identity {
  Authenticated(user_id: Int)
  Anonymous
}

pub fn resolve(_server_context: ServerContext, _session_id: String) -> Result(Identity, Nil) {
  Ok(Anonymous)
}

pub fn is_authenticated(identity: Identity) -> Bool {
  case identity { Authenticated(..) -> True  Anonymous -> False }
}

pub const redirect_url = "/login"
GLEAM

# --- public/client_context_server.gleam ---
cat > "$APP_DIR/src/public/client_context_server.gleam" <<'GLEAM'
import public/auth
import server_context.{type ServerContext}

pub type ClientContext { ClientContext }

pub fn from_session(
  server_context server_context: ServerContext,
  session_id _session_id: String,
  hostname _hostname: String,
  identity _identity: auth.Identity,
) -> #(ClientContext, ServerContext) {
  #(ClientContext, server_context)
}
GLEAM

# --- public/pages/home_.gleam: zero-handler namespace ---
cat > "$APP_DIR/src/public/pages/home_.gleam" <<'GLEAM'
import lustre/element
import lustre/effect

pub type Model { Model }
pub type Msg { NoOp }

pub fn init() -> #(Model, effect.Effect(Msg)) { #(Model, effect.none()) }
pub fn view(_model: Model) -> element.Element(Msg) { element.none() }
pub fn update(model: Model, _msg: Msg) -> #(Model, effect.Effect(Msg)) { #(model, effect.none()) }
GLEAM

# --- Dummy test file ---
cat > "$APP_DIR/test/auth_check_test.gleam" <<'GLEAM'
import gleeunit
import gleeunit/should

pub fn main() { gleeunit.main() }
pub fn dummy_test() { 1 |> should.equal(1) }
GLEAM

# --- Codegen ---
cd "$APP_DIR"
echo "Running codegen..."
gleam run -m rally > /dev/null

# --- Build ---
echo "Building..."
gleam build

echo "PASS: auth codegen produces compilable output"
